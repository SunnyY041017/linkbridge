# LinkBridge 环境变量配置
# 复制此文件为 .env 并填入真实值

# === 必填：大模型 API ===
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# === 可选：其他 LLM Provider（多模型路由） ===
TONGYI_API_KEY=
ZHIPU_API_KEY=

# === 数据库（Phase 3+ 使用） ===
DATABASE_URL=postgresql+asyncpg://linkbridge:linkbridge_dev@localhost:5432/linkbridge
DATABASE_URL_SYNC=postgresql://linkbridge:linkbridge_dev@localhost:5432/linkbridge

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === JWT ===
JWT_SECRET=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# === App ===
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
